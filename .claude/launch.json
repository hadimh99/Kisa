{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "concept-ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true,
      "cwd": "concept-ui"
    },
    {
      "name": "concept-api",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.js"],
      "port": 8000,
      "autoPort": false,
      "cwd": "concept-api"
    },
    {
      "name": "concept-atlas-py",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["server.py"],
      "port": 8000,
      "cwd": "."
    }
  ]
}
